# ==============================================================================
# UCLAW 环境变量模板
# 用法：
# 1. 复制本文件为 .env
# 2. 只填“必填 / 推荐填写”部分
# 3. 不确定的先留空，系统会优先读 .env，没有时再读数据库设置
# ------------------------------------------------------------------------------
# 注意：
# - 主变量统一使用 UCLAW_* 命名
# - 运行时兼容旧别名 LOBSTERAI_*，但新部署不要再写旧名字
# - 自动化平台通常会注入 PORT，请不要强行写死成别的平台端口
# ==============================================================================

# ------------------------------------------------------------------------------
# A. 基础运行配置
# ------------------------------------------------------------------------------
# 开发环境：development
# 生产环境：production
NODE_ENV=development

# 默认端口是 3001。
# Render / Railway / Koyeb / Docker 等平台通常会自动注入 PORT，
# 这时保留默认值即可，平台值会覆盖它。
PORT=3001

# 允许跨域来源。
# 单体部署可先用 *；
# 若前后端分离，建议改成明确域名，如 https://your-domain.com
CORS_ORIGIN=*

# ------------------------------------------------------------------------------
# B. 数据目录与工作目录
# ------------------------------------------------------------------------------
# 默认数据目录为：./.uclaw/web
# 若要自定义，请务必放在“项目根目录内部”，否则运行时会自动忽略并回退默认目录。
# 推荐：
# UCLAW_DATA_PATH=.uclaw
# 或平台项目内绝对路径：
# UCLAW_DATA_PATH=/opt/render/project/src/.uclaw
# UCLAW_DATA_PATH=

# 一般不用手填。服务启动时会自动推断项目根目录。
# 只有在非常规启动方式下才需要覆盖。
# UCLAW_APP_ROOT=
# UCLAW_WORKSPACE=

# ------------------------------------------------------------------------------
# C. 模型 API 配置
# ------------------------------------------------------------------------------
# 这是最常用的一组配置。
# 可以直接写在 .env，也可以首启后去 UI 设置页填写。
# 如果这里留空，且数据库里也没配置，对话能力无法正常工作。
UCLAW_API_BASE_URL=
UCLAW_API_KEY=
UCLAW_DEFAULT_MODEL=

# 示例：
# UCLAW_API_BASE_URL=https://api.openai.com/v1
# UCLAW_API_KEY=sk-xxxx
# UCLAW_DEFAULT_MODEL=gpt-5.4

# ------------------------------------------------------------------------------
# D. 飞书集成（可选）
# ------------------------------------------------------------------------------
# 只有要启用飞书机器人时才填写。
# 不填不会影响普通 Web 使用。
# UCLAW_FEISHU_APP_ID=
# UCLAW_FEISHU_APP_SECRET=
# UCLAW_FEISHU_AGENT_ROLE_KEY=organizer

# ------------------------------------------------------------------------------
# E. 每日记忆摘要模型（可选）
# ------------------------------------------------------------------------------
# 如果想把“每日记忆总结”绑定到单独的小模型，可填写这组。
# 不填则沿用主配置或数据库设置。
# UCLAW_DAILY_MEMORY_API_BASE_URL=
# UCLAW_DAILY_MEMORY_API_KEY=
# UCLAW_DAILY_MEMORY_MODEL=Qwen/Qwen3.5-4B
# UCLAW_DAILY_MEMORY_API_FORMAT=openai

# ------------------------------------------------------------------------------
# F. 兼容说明
# ------------------------------------------------------------------------------
# 以下旧变量名仍兼容读取，但不建议新项目继续使用：
# - LOBSTERAI_APP_ROOT
# - LOBSTERAI_WORKSPACE
# - LOBSTERAI_DATA_PATH
# - LOBSTERAI_API_BASE_URL
# - LOBSTERAI_API_KEY
# - LOBSTERAI_DEFAULT_MODEL
