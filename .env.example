# ==============================================================================
# UCLAW 环境变量配置
# 使用方法：复制本文件为 .env，然后填入你自己的密钥
#   复制命令：cp .env.example .env
# ==============================================================================

# ------------------------------------------------------------------------------
# 基础配置（一般不用改）
# ------------------------------------------------------------------------------
NODE_ENV=development
PORT=3001
CORS_ORIGIN=*

# ------------------------------------------------------------------------------
# 数据存储路径（可选，默认在项目内 ./.uclaw/）
# ------------------------------------------------------------------------------
# UCLAW_DATA_PATH=
# UCLAW_APP_ROOT=

# ------------------------------------------------------------------------------
# API 配置 — 填你自己的 API 地址和密钥
# 也可以不填这里，直接在软件「设置」页面配置
# 主名使用 UCLAW_*，同时兼容读取旧的 LOBSTERAI_* 变量
# ------------------------------------------------------------------------------
UCLAW_API_BASE_URL=
UCLAW_API_KEY=
UCLAW_DEFAULT_MODEL=

# ------------------------------------------------------------------------------
# 飞书集成（可选 - 需要飞书机器人时填写）
# ------------------------------------------------------------------------------
# UCLAW_FEISHU_APP_ID=
# UCLAW_FEISHU_APP_SECRET=
# UCLAW_FEISHU_AGENT_ROLE_KEY=organizer

# ------------------------------------------------------------------------------
# 每日记忆摘要（可选 - 单独绑定便宜稳定模型，避免占用主对话角色）
# ------------------------------------------------------------------------------
# UCLAW_DAILY_MEMORY_API_BASE_URL=
# UCLAW_DAILY_MEMORY_API_KEY=
# UCLAW_DAILY_MEMORY_MODEL=Qwen/Qwen3.5-4B
# UCLAW_DAILY_MEMORY_API_FORMAT=openai
